<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
	<TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <AssemblyName>IxianDLT</AssemblyName>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <DefineConstants>$(DefineConstants);LINUX</DefineConstants>
  </PropertyGroup>
  
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('macOS'))">
    <DefineConstants>$(DefineConstants);MACCATALYST</DefineConstants>
  </PropertyGroup>
  
  <Import Project="..\..\Ixian-Core\IXICore.projitems" Label="Shared" />
    
  <ItemGroup>
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.6.2" />
    <PackageReference Include="FluentCommandLineParser-netstandard" Version="1.4.3.13" />
    <PackageReference Include="Mono.Nat" Version="3.0.4" />
    <PackageReference Include="RocksDB" Version="10.4.2.64152" />
    <PackageReference Include="sqlite-net-pcl" Version="1.9.172" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="System.Diagnostics.PerformanceCounter" Version="10.0.5" />
  </ItemGroup>
  
  <PropertyGroup>
    <ApplicationIcon>IxianDLT.ico</ApplicationIcon>
    <AssemblyName>IxianDLT</AssemblyName>
    <AssemblyTitle>Ixian DLT</AssemblyTitle>
    <AssemblyDescription></AssemblyDescription>
    <AssemblyCompany>Ixian</AssemblyCompany>
    <Product>Ixian DLT</Product>
    <Copyright>Copyright © 2026 Ixian</Copyright>
    <VersionPrefix>0.9.8.1</VersionPrefix>
    <PackageProjectUrl>https://www.ixian.io</PackageProjectUrl>
    <CLSCompliant>true</CLSCompliant>
    <ComVisible>false</ComVisible>
  </PropertyGroup>
  
  <ItemGroup>
    <Content Include="IxianDLT.ico" />
  </ItemGroup>
  
  <Target Name="CopyHTMLToOutput" AfterTargets="CoreCompile">
    <ItemGroup>
      <IXIPB1 Include="$(SolutionDir)\..\Ixian-Core\html\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(IXIPB1)" DestinationFolder="$(OutputPath)\html\%(RecursiveDir)" ContinueOnError="true" />
  </Target>
</Project>